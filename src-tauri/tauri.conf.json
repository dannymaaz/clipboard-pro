{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard Pro",
  "version": "0.1.7",
  "identifier": "com.dannymaaz.clipboardpro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright Danny Maaz",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Fast local clipboard upgrade",
    "longDescription": "Clipboard Pro is a fast, private, local-first clipboard manager for Windows, macOS and Linux."
  }
}
